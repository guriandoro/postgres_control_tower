# Demo-only secrets. Copy to .env (ignored by git) and edit if desired.
# `bootstrap.sh` will create this file with safe random defaults if it
# doesn't already exist.

PCT_JWT_SECRET=demo-jwt-secret-please-change
PCT_ENROLLMENT_TOKEN=demo-enrollment-token-please-change
PCT_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
PCT_BOOTSTRAP_ADMIN_PASSWORD=admin

# Manager DB
PCT_MGR_DB_USER=pct
PCT_MGR_DB_PASSWORD=pct
PCT_MGR_DB_NAME=pct

# Optional Slack / SMTP — unset means notifier disabled.
PCT_SLACK_WEBHOOK_URL=
PCT_SMTP_HOST=
PCT_SMTP_TO=
