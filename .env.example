# Manager configuration. Copy to .env and edit.
# All variables are prefixed with PCT_ when read from env.

# --- Database ---
PCT_DATABASE_URL=postgresql+psycopg://pct:pct@localhost:5432/pct

# --- JWT (UI users) ---
PCT_JWT_SECRET=change-me-to-a-long-random-string
PCT_JWT_ALGORITHM=HS256
PCT_JWT_EXPIRE_MINUTES=1440

# --- Agent enrollment ---
# Shared secret presented by an agent during initial /agents/register call.
# Rotate by changing this value and re-registering agents.
PCT_ENROLLMENT_TOKEN=change-me-enrollment-token

# --- Bootstrap admin ---
# If set and no admin user exists, an admin will be created at manager startup.
PCT_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
PCT_BOOTSTRAP_ADMIN_PASSWORD=admin

# --- Retention (logs.events) ---
PCT_LOG_RETENTION_DAYS=14

# --- UI ---
# Built Vite app to serve as a SPA at /. Set in the prod image; leave empty
# during dev (the Vite dev server runs separately on :5173).
PCT_WEB_DIST_DIR=
# Comma-separated CORS origins. Default allows the Vite dev server.
PCT_CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Alerting (P7) ---
# Rule eval cadence (seconds) and renotify throttle for still-open alerts.
PCT_ALERT_EVAL_INTERVAL=60
PCT_ALERT_RENOTIFY_SECONDS=21600

# Storage runway forecast cadence + lookback window.
PCT_FORECAST_INTERVAL_SECONDS=300
PCT_FORECAST_WINDOW_DAYS=7
# Optional fleet-wide bytes cap used for "days to full". 0 disables runway.
PCT_FORECAST_TARGET_BYTES=0

# --- Notifiers ---
# Slack webhook URL. Empty disables the Slack notifier.
PCT_SLACK_WEBHOOK_URL=

# SMTP. Empty PCT_SMTP_HOST or PCT_SMTP_TO disables the SMTP notifier.
PCT_SMTP_HOST=
PCT_SMTP_PORT=587
PCT_SMTP_USERNAME=
PCT_SMTP_PASSWORD=
PCT_SMTP_USE_TLS=true
PCT_SMTP_FROM=pct@localhost
# Comma-separated recipient list.
PCT_SMTP_TO=

# ============================================================================
# Agent-only settings (consumed by `pct-agent`, prefixed with PCT_AGENT_)
# ============================================================================

# Manager URL the agent points at.
PCT_AGENT_MANAGER_URL=http://localhost:8080

# Heartbeat cadence (seconds).
PCT_AGENT_HEARTBEAT_INTERVAL=30

# --- WAL collector ---
# libpq DSN for the local Postgres. Empty disables the WAL collector.
PCT_AGENT_PG_DSN=
PCT_AGENT_WAL_INTERVAL=30

# --- pgBackRest collector ---
PCT_AGENT_PGBACKREST_BIN=pgbackrest
# Optional: scope to one stanza. Empty = all configured stanzas.
PCT_AGENT_PGBACKREST_STANZA=
PCT_AGENT_PGBACKREST_INTERVAL=60

# --- Log file collectors (one or more comma-separated paths per source) ---
# Empty disables that source. See docs/log-sources.md for typical defaults.
PCT_AGENT_PG_LOG_PATHS=
PCT_AGENT_PGBACKREST_LOG_PATHS=
PCT_AGENT_PATRONI_LOG_PATHS=
PCT_AGENT_ETCD_LOG_PATHS=
# Use journalctl by default for the OS source; this is for fallback files only.
PCT_AGENT_OS_LOG_PATHS=

# --- Shipper ---
PCT_AGENT_SHIPPER_BATCH_SIZE=200
PCT_AGENT_SHIPPER_FLUSH_INTERVAL=5.0
PCT_AGENT_SPOOL_DIR=/var/lib/pct-agent/spool

# --- Job runner (Safe Ops) ---
# Long-poll seconds for /jobs/next. 0 disables the runner entirely.
PCT_AGENT_RUNNER_LONG_POLL_SECONDS=25
# Per-job hard timeout (seconds). Default 6h; override for very large DBs.
PCT_AGENT_RUNNER_JOB_TIMEOUT_SECONDS=21600
# Last-N chars of stdout shipped back with each job result.
PCT_AGENT_RUNNER_STDOUT_TAIL_CHARS=16000
